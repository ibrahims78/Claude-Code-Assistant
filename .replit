modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Claude Education"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WhatsApp Dashboard"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "Claude Education"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=25013 BASE_PATH=/education/ pnpm --filter @workspace/claude-education run dev"
waitForPort = 25013

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "WhatsApp Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=23097 BASE_PATH=/whatsapp/ pnpm --filter @workspace/whatsapp-dashboard run dev"
waitForPort = 23097

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 23097
externalPort = 3000

[[ports]]
localPort = 23098
externalPort = 3002

[[ports]]
localPort = 25013
externalPort = 3001

[[ports]]
localPort = 25014
externalPort = 3003

[[ports]]
localPort = 25015
externalPort = 4200

[nix]
channel = "stable-25_05"

[userenv]

